-- =============================================================================
-- Deal title suffix cleanup — one-off, STAGED for review (DO NOT auto-apply)
-- Migration: 20260624000000_cleanup_deal_title_suffixes
-- Lives in staged-migrations/ (NOT supabase/migrations/) so it cannot run on
-- a Vercel/Supabase deploy. Run manually via the Supabase SQL editor or CLI
-- only after Jordan's sign-off.
-- =============================================================================
--
-- CORRECTED after Codex review (24/06/2026). Two P1s fixed:
--   1. Removed the deals.source backfill — that column DOES NOT EXIST on
--      public.deals (verified live: deals has no `source` column).
--   2. The org guard is now an ACTIVE predicate on every UPDATE (Jordan's org
--      hardcoded), not a commented-out line.
--
-- LIVE DATA AUDIT (24/06/2026, against project bsevgxhnxlkzkcalevbb):
--   total deals in Purezza AU org : 340
--   " — Purezza intro" suffix     : 15   <-- the ONLY rows this migration touches
--   " from PST" suffix             : 0    (already cleaned by 20260612071902)
--   "[WALK-xxxx]" prefix           : 6    <-- TEST/QA FIXTURE deals, NOT touched here
--                                            (e.g. "Zero-value deal", "Orphan deal",
--                                             "Far-future next-step (2099)") — these
--                                             are synthetic test rows; deleting/cleaning
--                                             them is a separate decision for Jordan.
--   raw domain titles (257)        : handled at DISPLAY by cleanDomain() — no stored
--                                     change needed; render shows "Industrykitchens" etc.
--
-- All 15 "Purezza intro" rows ALREADY have temperature='cold', so NO temperature
-- backfill is needed. This migration does exactly one thing: strip the suffix.
--
-- SCOPE: Purezza AU org only — 5557189e-5c2d-4990-afad-6aa1861826cd
-- IDEMPOTENT: WHERE checks the suffix is present; safe to re-run (no-op 2nd time).
-- =============================================================================

-- ---------------------------------------------------------------------------
-- Safety guard: abort if the org id is wrong/missing.
-- ---------------------------------------------------------------------------
do $$
begin
  if not exists (
    select 1 from public.orgs where id = '5557189e-5c2d-4990-afad-6aa1861826cd'
  ) then
    raise exception 'STOP: Purezza AU org id not found — do not run against the wrong project';
  end if;
end $$;

-- ---------------------------------------------------------------------------
-- Preview (run this SELECT FIRST to see exactly what will change):
-- ---------------------------------------------------------------------------
-- select id, title,
--        trim(regexp_replace(title, '\s*[—-]\s*Purezza\s+intro', '', 'gi')) as new_title
--   from public.deals
--  where org_id = '5557189e-5c2d-4990-afad-6aa1861826cd'::uuid
--    and title ~* '\s*[—-]\s*Purezza\s+intro'
--  order by title;
-- Expected: 15 rows, e.g. "Chronicles Bar — Purezza intro" -> "Chronicles Bar"

-- ---------------------------------------------------------------------------
-- The one operation: strip " — Purezza intro" from the 15 titles.
-- ---------------------------------------------------------------------------
update public.deals
   set title      = trim(regexp_replace(title, '\s*[—-]\s*Purezza\s+intro', '', 'gi')),
       updated_at = now()
 where org_id = '5557189e-5c2d-4990-afad-6aa1861826cd'::uuid
   and title ~* '\s*[—-]\s*Purezza\s+intro'
   -- only if the result actually changes and isn't empty
   and trim(regexp_replace(title, '\s*[—-]\s*Purezza\s+intro', '', 'gi')) <> title
   and trim(regexp_replace(title, '\s*[—-]\s*Purezza\s+intro', '', 'gi')) <> '';

-- ---------------------------------------------------------------------------
-- Post-run verify (expect 0 rows):
-- ---------------------------------------------------------------------------
-- select count(*) from public.deals
--  where org_id = '5557189e-5c2d-4990-afad-6aa1861826cd'::uuid
--    and title ~* 'Purezza\s+intro';

-- =============================================================================
-- NOT INCLUDED (deliberately):
--   * deals.source backfill  — column does not exist
--   * temperature backfill   — all target rows already temperature='cold'
--   * "from PST" strip        — 0 matching rows
--   * "[WALK-xxxx]" strip     — those are test fixtures; Jordan decides separately
-- =============================================================================
