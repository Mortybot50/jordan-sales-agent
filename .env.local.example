# =============================================================================
# LeadFlow Jordan Sales Agent — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.
# See docs/env-vars.md for full docs on each variable.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (required — Week 1)
# Get from: supabase.com → project → Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Service role key — NEVER expose to browser. Used by Edge Functions / Vercel API routes only.
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# -----------------------------------------------------------------------------
# OUTBOUND EMAIL — Instantly.ai (GATE-4 pending Morty setup)
# TODO(week-4): Fill in once Instantly.ai account is live
# -----------------------------------------------------------------------------
# INSTANTLY_API_KEY=
# INSTANTLY_CAMPAIGN_ID=

# -----------------------------------------------------------------------------
# TRANSACTIONAL EMAIL — SendGrid (for briefing digest, notifications)
# TODO(week-4): Configure SendGrid for transactional emails
# -----------------------------------------------------------------------------
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# -----------------------------------------------------------------------------
# GMAIL OAUTH — Inbound reply watching (GATE-6 pending — 4-6 week lead time)
# TODO(week-4): Fill in once Google Cloud OAuth app is verified
# Architecture decision: Jordan uses his personal Gmail (GATE-1 resolved 2026-04-21)
# NOT using outreach.purezza.com.au — Jordan is not restricted to Purezza tooling
# -----------------------------------------------------------------------------
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GOOGLE_CLOUD_PROJECT_ID=
# PUBSUB_TOPIC_NAME=

# -----------------------------------------------------------------------------
# AI DRAFTING — Claude API (Week 3)
# Dedicated Anthropic project key for LeadFlow-Jordan (separate from Morty's personal key)
# TODO(week-3): Create new Anthropic project "LeadFlow-Jordan" and add key here
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# GOOGLE PLACES API — Venue auto-sourcing (Week 6)
# Set GCP quota limit to 500 calls/day to prevent runaway billing
# TODO(week-6): Enable Places API in GCP console + set quota
# -----------------------------------------------------------------------------
# GOOGLE_PLACES_API_KEY=

# -----------------------------------------------------------------------------
# PROXYCURL — LinkedIn enrichment for leadership change signals (Week 7)
# ~$0.01/profile, ~$60/mo for 200 active contacts
# TODO(week-7): Add Proxycurl key once LinkedIn signal worker is built
# -----------------------------------------------------------------------------
# PROXYCURL_API_KEY=
# PROXYCURL_MOCK=true  # Set to 'true' in local dev to skip real API calls

# -----------------------------------------------------------------------------
# UNSUBSCRIBE — Spam Act 2003 compliance (Week 9)
# Secret for HMAC-SHA256 token generation: HMAC(UNSUBSCRIBE_SECRET, email+org_id)
# TODO(week-9): Generate a random 32-byte secret and store in Vercel env
# -----------------------------------------------------------------------------
# UNSUBSCRIBE_SECRET=

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
VITE_APP_ENV=development
# VITE_APP_ENV=production
