{
  "name": "jordan-sales-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --test --experimental-strip-types --no-warnings tests/*.test.mts && vitest run",
    "preview": "vite preview",
    "smoke": "bash scripts/smoke-api.sh",
    "classify-backlog": "deno run --allow-env --allow-net scripts/classify-backlog.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test tests/e2e/smoke.spec.ts",
    "ci": "npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
